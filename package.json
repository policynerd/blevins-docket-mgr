{
  "name": "blevins-docket-mgr",
  "version": "0.1.0",
  "description": "Legislative docket & agenda management system (Legistar-style) with zero runtime dependencies.",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node --experimental-sqlite --no-warnings server.js",
    "seed": "node --experimental-sqlite --no-warnings src/seed.js --reset",
    "reset": "node --experimental-sqlite --no-warnings src/seed.js --reset",
    "test": "node --experimental-sqlite --no-warnings --test",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link --project-ref qpoupyodhhiupgalgbuf",
    "supabase:push": "npx supabase db push",
    "supabase:migrations": "npx supabase migration list"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "MIT"
}
