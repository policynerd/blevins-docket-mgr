# Copy to `.env` for local use. Everything here is OPTIONAL — the app boots with
# sensible defaults. Set values to adapt the deployment to your organization.

# ─────────────────────────────────────────────────────────────────────────────
# Organization identity / branding
# Every label in the UI is derived from these, so you can rebrand the whole app
# to your organization without touching code. Defaults describe a Board of
# Governors. Quote values that contain spaces.
# ─────────────────────────────────────────────────────────────────────────────
# ORG_NAME="Board of Governors"
# ORG_TAGLINE="Legislative Information Center"
# ORG_SEAL="★"                                   # placeholder emblem glyph
# ORG_PRIMARY_BODY="Board of Governors"
# ORG_PRIMARY_BODY_TYPE="Governing Board"
# ORG_MEMBERS_LABEL="Board Members"              # nav + members listing label
# ORG_CHAIR_TITLE="Chair"
# ORG_VICE_CHAIR_TITLE="Vice Chair"
# ORG_MEMBER_TITLE="Governor"
# ORG_CLERK_TITLE="Clerk of the Board"
# ORG_CLERK_OFFICE="Office of the Clerk of the Board"
# ORG_MEETING_LOCATION="Boardroom"
# ORG_EMAIL_DOMAIN="board.gov"                   # used for demo account emails

# ─────────────────────────────────────────────────────────────────────────────
# Server / runtime
# ─────────────────────────────────────────────────────────────────────────────
# PORT=3000
# DOCKET_DB=./data/docket.db                     # point at a mounted volume in prod
# NODE_ENV=production                            # marks session cookies Secure

# ─────────────────────────────────────────────────────────────────────────────
# First-boot account seeding (only when the database has no users yet).
# Sample people/bodies/matters always auto-seed; LOGIN accounts do not unless
# you choose ONE of the options below.
# ─────────────────────────────────────────────────────────────────────────────
# A) Explicit administrator — recommended for production.
# ADMIN_EMAIL="clerk@board.gov"
# ADMIN_PASSWORD="change-me-at-least-12-chars"
# ADMIN_NAME="Administrator"
#
# B) Demo logins (clerk + board members with known passwords) — local/eval only.
# ENABLE_DEMO_SEED=true

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (optional / legacy) — NOT used by the SQLite runtime. Present only
# for the standalone supabase config helper + its tests. Leave unset for the
# default SQLite + Fly deployment.
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
