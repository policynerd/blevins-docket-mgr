# Copy to `.env` for local use. Everything here is OPTIONAL — the app boots with
# sensible defaults. Set values to adapt the deployment to your organization.

# ─────────────────────────────────────────────────────────────────────────────
# Organization identity / branding
# Every label in the UI is derived from these, so you can rebrand the whole app
# to your organization without touching code. Defaults describe a Board of
# Governors. Quote values that contain spaces. NOTE: these are starting
# defaults — once running, the Clerk can edit branding live at /admin/branding
# (stored in the database, which then overrides these env values).
# ─────────────────────────────────────────────────────────────────────────────
# ORG_NAME="Board of Governors"
# ORG_TAGLINE="Legislative Information Center"
# ORG_SEAL="★"                                   # placeholder glyph (no logo set)
# ORG_LOGO_URL="https://…/logo.png"             # https logo shown in the banner
# ORG_PRIMARY_COLOR="#15569e"                    # hex brand color
# ORG_PRIMARY_BODY="Board of Governors"
# ORG_PRIMARY_BODY_TYPE="Governing Board"
# ORG_MEMBERS_LABEL="Board Members"              # nav + members listing label
# ORG_CHAIR_TITLE="Chair"
# ORG_VICE_CHAIR_TITLE="Vice Chair"
# ORG_MEMBER_TITLE="Governor"
# ORG_CLERK_TITLE="Clerk of the Board"
# ORG_CLERK_OFFICE="Office of the Clerk of the Board"
# ORG_MEETING_LOCATION="Boardroom"
# ORG_EMAIL_DOMAIN="board.gov"                   # used for demo account emails

# ─────────────────────────────────────────────────────────────────────────────
# Server / runtime
# ─────────────────────────────────────────────────────────────────────────────
# PORT=3000
# DOCKET_DB=./data/docket.db                     # point at a mounted volume in prod
# NODE_ENV=production                            # marks session cookies Secure

# ─────────────────────────────────────────────────────────────────────────────
# First-boot data + account seeding.
# Production starts EMPTY: set ADMIN_EMAIL + ADMIN_PASSWORD to bootstrap a single
# clerk/admin login, then build real data in the app. Sample data + demo logins
# are created ONLY when ENABLE_DEMO_SEED=true (local/eval).
# ─────────────────────────────────────────────────────────────────────────────
# A) Explicit administrator — recommended for production.
# ADMIN_EMAIL="clerk@board.gov"
# ADMIN_PASSWORD="change-me-at-least-12-chars"
# ADMIN_NAME="Administrator"
#
# B) Demo data + logins (sample board, clerk + members) — local/eval only.
# ENABLE_DEMO_SEED=true

# ─────────────────────────────────────────────────────────────────────────────
# Single sign-on — Microsoft Entra ID (OIDC). When all three ENTRA_* values are
# set, a "Sign in with Microsoft" button appears on /login. An SSO user is matched
# to a local account by linked subject, then by email; otherwise sign-in is denied
# unless SSO_AUTO_PROVISION_ROLE is set. Local password login still works.
# ─────────────────────────────────────────────────────────────────────────────
# ENTRA_TENANT_ID="<tenant-guid-or-domain>"
# ENTRA_CLIENT_ID="<app-registration-client-id>"
# ENTRA_CLIENT_SECRET="<client-secret>"
# ENTRA_REDIRECT_URI="https://your-host/auth/sso/callback"   # optional; auto-derived
# SSO_AUTO_PROVISION_ROLE="member"   # optional: auto-create first-time SSO users

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (optional / legacy) — NOT used by the SQLite runtime. Present only
# for the standalone supabase config helper + its tests. Leave unset for the
# default SQLite + Fly deployment.
# ─────────────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_URL=
# SUPABASE_PUBLISHABLE_KEY=
